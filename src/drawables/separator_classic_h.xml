<!-- Classic horizontal separator: etched line pair centered vertically -->
<selector>
    <item>
        <layer-list>
            <item>
                <shape type="line" x1="0" y1="50%-1" x2="100%" y2="50%-1">
                    <stroke width="1" color="@border_light"/>
                </shape>
            </item>
            <item>
                <shape type="line" x1="0" y1="50%" x2="100%" y2="50%">
                    <stroke width="1" color="@highlight"/>
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
