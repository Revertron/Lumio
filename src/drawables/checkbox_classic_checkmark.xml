<!-- Classic checkbox checkmark: two strokes of a tick, inset 3 dips from the
     box (coordinates are the legacy inset-3 geometry expressed against the
     full box bounds). -->
<selector>
    <item>
        <layer-list>
            <item>
                <shape type="line" x1="3" y1="50%" x2="33.333%+1" y2="87.5%-2.25">
                    <stroke width="1" color="@text"/>
                </shape>
            </item>
            <item>
                <shape type="line" x1="33.333%+1" y1="87.5%-2.25" x2="100%-3" y2="12.5%+2.25">
                    <stroke width="1" color="@text"/>
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
