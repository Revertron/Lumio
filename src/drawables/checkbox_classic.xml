<!-- Classic Windows checkbox drawable (box only, checkmark drawn separately) -->
<selector>
    <!-- All states use same box -->
    <item>
        <layer-list>
            <!-- White background -->
            <item>
                <shape type="rect">
                    <solid color="@surface"/>
                </shape>
            </item>

            <!-- Inset border (same as edit field) -->
            <item>
                <shape type="rect">
                    <!-- Outer border: Gray on top-left -->
                    <stroke width="1" color="@border_light" top="0" left="0" right="1"/>
                    <stroke width="1" color="@border_light" left="0" top="0" bottom="1"/>

                    <!-- Inner shadow: Dark on top-left -->
                    <stroke width="1" color="@border_dark" top="1" left="1" right="1"/>
                    <stroke width="1" color="@border_dark" left="1" top="1" bottom="1"/>

                    <!-- Inner highlight: Background on bottom-right -->
                    <stroke width="1" color="@background" bottom="1" left="1" right="1"/>
                    <stroke width="1" color="@background" right="1" top="1" bottom="1"/>

                    <!-- Outer highlight: White on bottom -->
                    <stroke width="1" color="@highlight" bottom="0" left="1" right="1"/>
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
