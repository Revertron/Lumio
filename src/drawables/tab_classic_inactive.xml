<!-- Classic inactive tab: same raised borders, fill stays inside the tab. -->
<selector>
    <item>
        <layer-list>
            <item>
                <shape type="rect" x="1" y="1" width="100%-2" height="100%-2">
                    <solid color="@background"/>
                </shape>
            </item>
            <item>
                <shape type="line" x1="0" y1="0" x2="0" y2="100%">
                    <stroke width="1" color="@highlight"/>
                </shape>
            </item>
            <item>
                <shape type="line" x1="0" y1="0" x2="100%" y2="0">
                    <stroke width="1" color="@highlight"/>
                </shape>
            </item>
            <item>
                <shape type="line" x1="100%-1" y1="0" x2="100%-1" y2="100%">
                    <stroke width="1" color="@border_dark"/>
                </shape>
            </item>
            <item>
                <shape type="line" x1="100%-2" y1="1" x2="100%-2" y2="100%">
                    <stroke width="1" color="@border_light"/>
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
