<Frame id="main" width="min" height="max" direction="vertical" font="Noto Sans" font_style="Regular" padding="0">
    <Label id="label1" text="Label with NotoSans font" padding="4"/>
    <Frame id="buttons1" direction="horizontal" padding="0" width="min">
        <Button id="btn1" text="Button 1" margin="4" tooltip="This is Button 1"/>
        <Button id="btn2" text="Button 2" margin="4" width="300" tooltip="A wider button"/>
        <Button id="btn3" text="Popup menu" margin="4"/>
    </Frame>

    <Edit id="edit1" text="Some very very very long text to edit and test clipping" width="40%" margin="4"/>

    <CheckBox id="checkbox1" text="Create awesome GUI in Rust?" margin="4"/>

    <Separator width="max" height="3" padding="1" />

    <Frame width="min" height="min" direction="vertical" padding_right="4" background="#FFDD44">
        <RadioButton id="rb1" text="Option A" group="options"/>
        <RadioButton id="rb2" text="Option B" group="options"/>
        <RadioButton id="rb3" text="Option C" group="options" checked="true"/>
    </Frame>

    <Frame width="min" direction="horizontal">
        <!-- Pipe-separated attribute -->
        <ComboBox id="combo1" width="240" items="Option A|Option B|Option C" selected="0"/>

        <!-- Nested Item tags -->
        <ComboBox id="combo1" width="240" selected="2">
            <Item text="Very long Option A"/>
            <Item text="Very long Option B"/>
            <Item text="Option C"/>
        </ComboBox>
    </Frame>

    <Frame width="min" height="min">
        <List id="list1" width="300" height="500" margin_left="4"/>
        <ImageView id="my_image" width="218" margin_left="4" image="cats.jpg" />
        <RecyclerView id="my_list" width="max" height="500" margin_left="4" margin_right="4" padding="5" />
    </Frame>

    <Frame id="footer" width="40%" height="min" breaking="true" padding="4">
        <Button id="btn7" text="Tlačidlo 7"/>
        <Button id="btn8" text="Кнопка 8"/>
        <Button id="btn9" text="Show dialog" width="min"/>
        <ImageButton id="play_btn" image="send.png" hover_image="send-hover.png" no_inset="true" width="24" height="24"/>
    </Frame>

    <Frame id="test" width="40%" height="min">
        <Edit id="edit2" text="Second very very very long text to edit and test clipping" width="max" margin="4"/>
    </Frame>

    <Edit id="edit4" text="Fourth very very very long text to edit and test clipping" width="max" margin="4"/>
</Frame>