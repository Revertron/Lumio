<Frame id="contact_item" width="max" height="min" direction="horizontal" padding="8" font_size="24">
    <ImageView id="avatar" width="48" height="48" image="avatar.png" margin_right="8"/>
    <Frame id="contact_info" width="max" height="min" direction="vertical" padding="0">
        <Frame id="top_row" width="max" height="min" direction="horizontal" padding="0">
            <Label id="contact_name" text="Name" width="min" font_style="Bold" margin_right="8"/>
            <Label id="contact_time" text="12:00" width="min" gravity="right" font_size="14"/>
        </Frame>
        <Label id="contact_last_msg" text="Last message..." width="max" margin_top="2" font_size="20"/>
    </Frame>
</Frame>
